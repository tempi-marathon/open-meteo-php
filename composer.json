{
  "name": "tempi-marathon/open-meteo-php",
  "description": "Saloon SDK for the Open-Meteo APIs",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "saloonphp/saloon": "^4.0"
  },
  "require-dev": {
    "laravel/pint": "^1.27",
    "orchestra/testbench": "^10.0|^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-mutate": "^4.0",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "TempiMarathon\\OpenMeteo\\": "src/",
      "TempiMarathon\\OpenMeteo\\Laravel\\": "laravel/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TempiMarathon\\OpenMeteo\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "generate": [
      "@php scripts/generate-hourly-daily-enums.php",
      "@php scripts/generate-timezones.php",
      "@php scripts/generate-country-codes.php",
      "@php scripts/generate-air-quality-enum.php",
      "@php scripts/generate-endpoint-enums.php",
      "@php scripts/generate-models-enums.php"
    ],
    "test": [
      "@test:style",
      "@test:types",
      "@test:unit"
    ],
    "test:style": "vendor/bin/pint --test",
    "test:types": "vendor/bin/phpstan analyse --no-progress",
    "test:unit": "vendor/bin/pest --coverage --min=100 --exclude-group=live",
    "test:mutation": "vendor/bin/pest --mutate --min=90 --parallel --exclude-group=live"
  },
  "suggest": {
    "illuminate/support": "Required for Laravel integration (^12.0|^13.0)"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "TempiMarathon\\OpenMeteo\\Laravel\\OpenMeteoServiceProvider"
      ]
    }
  }
}
